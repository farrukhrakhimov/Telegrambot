# Telegram bot token from @BotFather.
BOT_TOKEN=

# Telegram numeric user IDs allowed to use superadmin-only settings commands.
SUPERADMIN_IDS=123,456

# Number of warnings before automatic mute.
WARN_LIMIT=3

# Number of warnings before automatic ban.
BAN_LIMIT=5

# Automatic mute duration after WARN_LIMIT is reached: 10m, 2h, 1d, 7d.
AUTO_MUTE_DURATION=1h

# Comma-separated forbidden words; matched case-insensitively.
FORBIDDEN_WORDS=word1,word2

# Greeting for new members. Supports {name} and {chat}.
WELCOME_MESSAGE=Welcome {name}!

# Group rules shown by /rules. Use \n for line breaks in .env files.
RULES=1. Be respectful\n2. No spam

# Whether external links are allowed in regular messages.
LINKS_ALLOWED=false

# Whether new users must solve a math captcha within 60 seconds.
CAPTCHA_ENABLED=true

# Whether join/leave service messages should be deleted.
DELETE_SERVICE_MESSAGES=true

# Whether messages containing both Arabic and Cyrillic scripts should be deleted and warned.
MIXED_SCRIPT_FILTER_ENABLED=false

# Sticker/GIF messages in a row before deletion starts.
STICKER_GIF_FLOOD_LIMIT=3

# Loguru log level.
LOG_LEVEL=INFO

# SQLite database path. Parent directories are created automatically.
DATABASE_PATH=data/bot.db
